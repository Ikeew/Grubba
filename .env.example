# ─── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=grubba_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=grubba_db

# ─── API / Backend ─────────────────────────────────────────────────────────────
APP_NAME="Grubba Logística Portuária"
APP_ENV=production
DEBUG=false

# Construída automaticamente pelo compose — não edite se estiver usando Docker
DATABASE_URL=postgresql://grubba_user:troque_esta_senha@db:5432/grubba_db

# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_esta_chave_secreta_minimo_64_chars

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# Domínio público da VPS (sem barra). Em produção: https://seudominio.com
ALLOWED_ORIGINS=http://localhost

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Deixe vazio para usar proxy relativo via nginx (recomendado em produção)
VITE_API_URL=
